# =============================================
# FoodRush — Root .env for Docker Compose
# Copy this to .env and fill in your values
# =============================================

# Database
DB_NAME=foodrush_db
DB_USER=postgres
DB_PASSWORD=change_this_password_in_production

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64char_string_in_production
JWT_EXPIRE=7d

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost

# React App URLs (injected at build time)
REACT_APP_API_URL=http://localhost/api

# Stripe (optional — leave as placeholder to skip payments)
STRIPE_SECRET_KEY=sk_test_placeholder
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
